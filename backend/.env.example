# Backend Configuration for React Native Mobile App

# Server Port
PORT=3001

# CORS Configuration
# For development, use * or specific origins
# For production, specify your mobile app's scheme and web domains
# Example: http://localhost:3000,exp://192.168.1.100:8081,myapp://
CORS_ORIGIN=*

# Node Environment
NODE_ENV=development

# App Configuration
# Issuer name shown in authenticator apps (e.g., Google Authenticator)
APP_ISSUER=MyAuthApp

# API Base Path (optional, for API versioning)
# API_BASE_PATH=/api/v1
